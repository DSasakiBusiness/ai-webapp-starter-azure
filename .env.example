# ============================================
# ai-webapp-starter-azure 環境変数テンプレート
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_webapp_dev?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_webapp_dev

# --- API Server ---
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# --- Web Server ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- AI / LLM ---
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Azure OpenAI (Azure 経由で LLM を使う場合)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Auth (将来拡張用) ---
# JWT_SECRET=your-jwt-secret-minimum-32-chars
# NEXTAUTH_SECRET=your-nextauth-secret
# NEXTAUTH_URL=http://localhost:3000

# --- Azure (デプロイ時) ---
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=rg-ai-webapp
# AZURE_LOCATION=japaneast

# --- PentAGI (セキュリティレビュー用 / ステージング限定) ---
# PENTAGI_API_URL=http://localhost:8080
# PENTAGI_API_KEY=your-pentagi-api-key
# PENTAGI_TARGET_URL=http://staging.example.com
