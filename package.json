{
  "name": "ai-webapp-starter-azure",
  "version": "0.1.0",
  "private": true,
  "description": "AI 特化 Web サービス開発スターター (Next.js + NestJS + Prisma + LLM + Azure)",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky",
    "knip": "knip",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,md}\"",
    "spell:words": "cspell --words-only --unique \"**/*.{ts,tsx,js,jsx,md}\" | sort",
    "circular": "madge --circular --extensions ts,tsx apps/ packages/",
    "deps:check": "depcheck",
    "deps:update": "ncu",
    "deps:update:apply": "ncu -u",
    "sort-pkg": "sort-package-json \"package.json\" \"apps/*/package.json\" \"packages/*/package.json\"",
    "quality": "npm run lint && npm run format:check && npm run spell && npm run knip && npm run circular",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:studio": "cd apps/api && npx prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm test-runner"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.48.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cspell": "^9.7.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "npm-check-updates": "^19.6.5",
    "prettier": "^3.3.0",
    "sort-package-json": "^3.6.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.0"
}
